# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000



# ── JWT ───────────────────────────────────────────────────
USER_JWT_SECRET=your-super-secret-user-jwt-key-min-64-chars
USER_JWT_EXPIRES_IN=4d
USER_REFRESH_SECRET=your-super-secret-user-refresh-key-min-64-chars
USER_REFRESH_EXPIRES_IN=30d

ADMIN_JWT_SECRET=your-super-secret-admin-jwt-key-min-64-chars
ADMIN_JWT_EXPIRES_IN=4d
ADMIN_REFRESH_SECRET=your-super-secret-admin-refresh-key-min-64-chars
ADMIN_REFRESH_EXPIRES_IN=30d

# ── Cookies ───────────────────────────────────────────────
COOKIE_SECURE=true
COOKIE_SAME_SITE=strict

# ── Email (for OTP / password reset) ──────────────────────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="El-Tanany <no-reply@el-tanany.com>"

# ── Admin Origin Security ─────────────────────────────────
ADMIN_ORIGIN_TOKEN=your-64-char-admin-origin-secret-here

# ── Default Admin ─────────────────────────────────────────
DEFAULT_ADMIN_EMAIL=admin@el-tanany.com
DEFAULT_ADMIN_PASS=change-me-12-char-min

# ── Misc ──────────────────────────────────────────────────
BCRYPT_ROUNDS=12
LOG_LEVEL=info

# ── Uploadthing ───────────────────────────────────────────
UPLOADTHING_SECRET=your-uploadthing-secret-key
UPLOADTHING_APP_ID=your-uploadthing-app-id
